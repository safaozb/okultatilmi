rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Özel Tatiller: Herkes okuyabilir, SADECE giriş yapmış (yetkili) kullanıcılar yazabilir/silebilir
    match /custom_holidays/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Ziyaretçi Sayacı: Herkes okuyabilir ve sayacı artırmak için yazabilir
    match /site_stats/{document=**} {
      allow read, write: if true;
    }

    // Push Bildirim Tokenları: Herkes kendi tokenını yazabilir
    match /fcm_tokens/{document=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Bildirim Gönderme İstekleri: Sadece admin tetikleyebilir
    match /notification_requests/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}